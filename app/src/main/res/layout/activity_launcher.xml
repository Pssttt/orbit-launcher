<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <ImageView
        android:id="@+id/wallpaper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_aurora"
        android:contentDescription="@null" />

    <!-- Reactive ambient glow that follows focus and takes the app's accent color -->
    <ImageView
        android:id="@+id/ambientGlow"
        android:layout_width="760dp"
        android:layout_height="760dp"
        android:src="@drawable/glow"
        android:alpha="0"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="20dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="48dp"
            android:paddingEnd="48dp"
            android:paddingBottom="26dp">

            <TextView
                android:id="@+id/appTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:letterSpacing="0.25"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/searchChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/chip_bg"
                android:focusable="true"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:text="@string/search"
                android:textColor="@color/chip_text"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/settingsChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:background="@drawable/chip_bg"
                android:focusable="true"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:text="@string/settings"
                android:textColor="@color/chip_text"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/clock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:fontFamily="sans-serif-light" />

            <TextView
                android:id="@+id/date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/categoryList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:paddingTop="44dp"
            android:paddingBottom="24dp"
            android:descendantFocusability="afterDescendants" />
    </LinearLayout>

    <TextView
        android:id="@+id/emptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="No apps found"
        android:textColor="@color/text_secondary"
        android:textSize="18sp"
        android:fontFamily="sans-serif"
        android:visibility="gone" />

    <!-- Ambient screensaver overlay (fades in after idle, dismissed by any key) -->
    <LinearLayout
        android:id="@+id/screensaver"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#D8000000"
        android:alpha="0"
        android:visibility="gone">

        <TextView
            android:id="@+id/saverClock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="96sp"
            android:fontFamily="sans-serif-thin" />

        <TextView
            android:id="@+id/saverDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_secondary"
            android:textSize="22sp"
            android:fontFamily="sans-serif-light" />
    </LinearLayout>
</FrameLayout>
