<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Read other apps' "watch next" entries for the Continue Watching row -->
    <uses-permission android:name="com.android.providers.tv.permission.READ_EPG_DATA" />
    <!-- Fetch watch-next poster art (http) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <!-- See other installed apps (package visibility, API 30+) -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:banner="@drawable/app_banner"
        android:icon="@drawable/app_banner"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Aurora">

        <activity
            android:name=".LauncherActivity"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenLayout|screenSize|smallestScreenSize|uiMode|density|fontScale"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="landscape"
            android:stateNotNeeded="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.Aurora" />

        <activity
            android:name=".SearchActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.Aurora"
            android:windowSoftInputMode="stateVisible" />

        <activity
            android:name=".ManageAppsActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.Aurora" />

        <activity
            android:name=".CategoriesActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.Aurora" />

    </application>

</manifest>
